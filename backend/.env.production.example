# Server Config
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://app.docclear.ae

# Database Config (MySQL 8)
DB_HOST=mysql-db
DB_PORT=3306
DB_NAME=docclear_prod
DB_USER=docclear_admin
DB_PASS=SET_STRONG_PASSWORD_HERE

# Security
# Generate a long, random string for JWT_SECRET
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRES_IN=24h

# Rate Limiting
RATELIMIT_MAX=100
RATELIMIT_WINDOW=900000
